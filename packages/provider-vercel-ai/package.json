{
  "name": "@onemem/vercel-ai-provider",
  "version": "0.1.4",
  "description": "OneMem provider for the Vercel AI SDK — wrap any model to record verifiable on-chain action traces",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@onemem/sdk-ts": "workspace:*"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=3.0.0 <4",
    "ai": ">=6.0.0 <7"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/provider": "^3.0.0",
    "@types/node": "^22.19.21",
    "ai": "^6.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
