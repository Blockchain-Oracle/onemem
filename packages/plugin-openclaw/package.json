{
  "name": "@onemem/oc-onemem",
  "version": "0.2.5",
  "description": "OneMem plugin for OpenClaw — adds verifiable on-chain action traces on top of oc-memwal",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "oc-onemem": "./bin/init.mjs"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "bin",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "@onemem/sdk-ts": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": ">=2026.6.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@mysten-incubation/oc-memwal": "^0.0.4",
    "@types/node": "^25.9.3",
    "openclaw": "^2026.6.6",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
