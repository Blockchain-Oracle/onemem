{
  "name": "@onemem/oc-onemem",
  "version": "0.1.0",
  "description": "OneMem plugin for OpenClaw — adds verifiable on-chain action traces on top of oc-memwal",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@mysten-incubation/oc-memwal": "^0.0.4",
    "@mysten/sui": "^2.17.0",
    "@onemem/sdk-ts": "workspace:*",
    "openclaw": "^2026.6.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
