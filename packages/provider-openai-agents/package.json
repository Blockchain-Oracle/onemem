{
  "name": "@onemem/openai-agents",
  "version": "0.1.2",
  "description": "OneMem provider for the OpenAI Agents SDK — record agent runs as verifiable on-chain action traces",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ."
  },
  "dependencies": {
    "@onemem/sdk-ts": "workspace:*"
  },
  "peerDependencies": {
    "@openai/agents": ">=0.11.0 <1"
  },
  "devDependencies": {
    "@openai/agents": "^0.11.0",
    "@types/node": "^22.19.21",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
