{
  "name": "@onemem/sdk-ts",
  "version": "0.1.0",
  "description": "OneMem TypeScript SDK — verifiable memory + trace SDK for AI agents on Sui + Walrus + Seal + MemWal",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "@mysten/seal": "^1.1.0"
  },
  "peerDependencies": {
    "@mysten-incubation/memwal": "^0.0.5"
  },
  "peerDependenciesMeta": {
    "@mysten-incubation/memwal": {
      "optional": false
    }
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
