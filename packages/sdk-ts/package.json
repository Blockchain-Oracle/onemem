{
  "name": "@onemem/sdk-ts",
  "version": "0.6.0",
  "description": "OneMem TypeScript SDK — verifiable memory + trace SDK for AI agents on Sui + Walrus + Seal + MemWal",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "bin"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mysten/seal": "^1.1.0",
    "@mysten/sui": "^2.17.0",
    "@mysten/walrus": "^1.1.7",
    "@noble/hashes": "^2.2.0"
  },
  "peerDependencies": {
    "@mysten-incubation/memwal": "^0.0.5"
  },
  "peerDependenciesMeta": {
    "@mysten-incubation/memwal": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "bin": {
    "onemem-trace": "./bin/onemem-trace.mjs",
    "onemem-memory": "./bin/onemem-memory.mjs"
  }
}
