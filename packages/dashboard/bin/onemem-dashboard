#!/usr/bin/env node
// Launches the OneMem dashboard's Next.js standalone server on PORT (default 4040).
// Per docs/05-our-architecture/06-dashboard/local-deploy.md, this is what `onemem dashboard` (CLI) spawns.

import { spawn } from "node:child_process";
import { fileURLToPath } from "node:url";
import { dirname, resolve } from "node:path";
import { existsSync } from "node:fs";

const __dirname = dirname(fileURLToPath(import.meta.url));
const port = process.env.PORT ?? "4040";
const packageRoot = resolve(__dirname, "..");
const standaloneServer = resolve(
  packageRoot,
  ".next",
  "standalone",
  "packages",
  "dashboard",
  "server.js",
);
const legacyStandaloneServer = resolve(packageRoot, ".next", "standalone", "server.js");
const serverPath = existsSync(standaloneServer) ? standaloneServer : legacyStandaloneServer;

// Local-mode default: bind loopback only. This launcher serves your private
// credentials + memory/trace inventory; 0.0.0.0 would expose it to the whole LAN.
// Advanced users can opt into a wider bind with HOST (e.g. HOST=0.0.0.0).
const host = process.env.HOST ?? "127.0.0.1";

const proc = spawn("node", [serverPath], {
  env: { ...process.env, PORT: port, HOSTNAME: host },
  stdio: "inherit",
});

proc.on("exit", (code) => process.exit(code ?? 0));
