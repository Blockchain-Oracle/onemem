{
  "name": "@onemem/dashboard",
  "version": "0.1.0",
  "description": "OneMem dashboard — verifiable memory + trace viewer for AI agents (Next.js 15 standalone; serves both localhost:4040 and the hosted-dashboard shell)",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "onemem-dashboard": "./bin/onemem-dashboard"
  },
  "files": [
    ".next/standalone",
    ".next/static",
    "public",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "next build",
    "start": "next start -p ${PORT:-4040}",
    "dev": "next dev -p 4040",
    "test": "vitest run --passWithNoTests",
    "browser:smoke": "node scripts/browser-smoke.mjs",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next out"
  },
  "dependencies": {
    "@mysten/dapp-kit": "^1.0.0",
    "@mysten/enoki": "^1.0.0",
    "@mysten/seal": "^1.1.0",
    "@mysten/sui": "^2.17.0",
    "@onemem/brand": "workspace:*",
    "@onemem/sdk-ts": "workspace:*",
    "@radix-ui/themes": "^3.2.0",
    "@tanstack/react-query": "^5.62.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.2.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "playwright-core": "^1.60.0",
    "postcss": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
