    "@onemem/brand": "workspace:*",
    "@onemem/dashboard": "workspace:*",
    "@onemem/sdk-ts": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "playwright-core": "^1.60.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
